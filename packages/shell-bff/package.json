{
  "private": true,
  "name": "@odh-dashboard/shell-bff",
  "description": "Lightweight BFF for the app shell — serves auth, config, and plugin manifest endpoints.",
  "version": "0.0.0",
  "scripts": {
    "start": "NODE_ENV=production node ./dist/server.js",
    "start:dev": "cross-env NODE_ENV=development nodemon",
    "build": "rimraf dist && tsc -p tsconfig.prod.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2"
  },
  "devDependencies": {
    "@odh-dashboard/eslint-config": "*",
    "@odh-dashboard/tsconfig": "*",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.7",
    "rimraf": "^6.0.1"
  }
}
